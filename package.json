{
  "name": "tr-bot",
  "version": "1.0.0",
  "description": "Telegram bot that converts Latin-transliterated Georgian text into proper Georgian script",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "telegram",
    "georgian",
    "transliteration",
    "mkhedruli"
  ],
  "license": "MIT",
  "dependencies": {
    "dotenv": "^17.3.1",
    "grammy": "^1.41.1"
  },
  "devDependencies": {
    "@types/node": "^25.4.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
